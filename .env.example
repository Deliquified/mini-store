PINATA_JWT=
NEXT_PUBLIC_GATEWAY_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PINATA_API_KEY=

NEXT_PUBLIC_UNIVERSAL_GRAPH_URL=

# --- App-open tracking / Trending (Upstash Redis) ---
# Provision via Vercel: Storage/Integrations -> Upstash -> Redis. The
# integration injects KV_REST_API_URL + KV_REST_API_TOKEN automatically in
# production. For local dev, copy the REST URL/token from the Upstash console.
# Leave blank to disable tracking — Trending then falls back to shuffled order.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Manual Upstash setups may instead use these (both naming schemes work):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
